# Copy this file to `.env` before running `make up`.
# Never commit `.env`.

# --- Compose database bootstrap -------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_STRING
POSTGRES_DB=convert_invert

# Used by the API container. The hostname must be `db` inside Docker Compose.
DATABASE_URL=postgresql://postgres:CHANGE_ME_TO_A_LONG_RANDOM_STRING@db:5432/convert_invert

# --- API / frontend shared auth -------------------------------------------
# Generate with: openssl rand -hex 32
API_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
ALLOWED_ORIGINS=http://localhost:5173

# --- Soulseek --------------------------------------------------------------
USER_NAME=your-soulseek-username
USER_PASSWORD=your-soulseek-password
LISTEN_PORT=41000
SHARE_LISTEN_PORT=41032
SHARE_RESCAN_INTERVAL_SECS=60

# --- Spotify ---------------------------------------------------------------
CLIENT_ID=your-spotify-client-id
CLIENT_SECRET=your-spotify-client-secret

# --- Optional service ports / runtime -------------------------------------
API_PORT=3124
FRONTEND_PORT=5173
JAEGER_UI_PORT=16686
OTLP_GRPC_PORT=4317
REDIS_URL=redis://redis:6379
RUN_ID=compose
LOG_LEVEL=info
WORKER_ACCOUNT_MODE=same
SHARE_MODE=external
SHARE_PATH=/downloads
